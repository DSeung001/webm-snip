{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebM Snip",
  "version": "0.1.0",
  "identifier": "com.webmsnip.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WebM Snip",
        "width": 1120,
        "height": 760,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Cut WebM clips locally.",
    "longDescription": "A lightweight local WebM cutter for screen recordings.",
    "icon": []
  }
}
